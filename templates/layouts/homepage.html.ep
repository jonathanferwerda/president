<!DOCTYPE html>
<html>
  <head>
		<% if (my $logo = &subs::setting_grabber({ app => 'me', setting => 'logo' })) { %>
			<link rel='icon' type='image/png' href="<%= $logo %>">
		<% } else { %>
		  <link rel='icon' type='image/png' href='/images/make believe/Pillow.png'/>
		<% } %>
		<script>
			var bti = sessionStorage.getItem('browser_tab_id'); 
			if (bti == null) { 
				console.log('bti is null');
				bti = '<%= $browser_tab_id %>';
				sessionStorage.setItem('browser_tab_id', '<%= $browser_tab_id %>'); 
			}
			var bt = localStorage.getItem('browser_tab');
			if (!bt) { 
				localStorage.setItem('browser_tab', '<%= $browser_tab %>');
			}
			var ws_url = '<%= $ws_url %>';
			var advertise_watching = '<%= $advertise_watching %>';
		</script>
    <title><%= title %></title>

		<meta charset="utf-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<script src="/js/jquery.js"></script>
		<script src="/js/numeral.min.js"></script>
		<script src="/js/universal.js?string=<%= $string %>"></script>
		<script src="/js/homepage.js?string=<%= $string %>"></script>
		<link rel="stylesheet" href="/css/store.css?string=<%= $string %>" />
		<link rel="stylesheet" href="/css/universal.css?string=<%= $string %>" />
		<% if ($c->session('authentication') eq 'approved') { %>
			<script src="/js/jquery-ui.js"></script>
			<script src="/js/jquery.ui.touch-punch.min.js"></script>
			<script src="/js/moment.js"></script>
			<script src="/js/mailbox.js?string=<%= $string %>"></script>
			<script src="/js/paperboy.js?string=<%= $string %>"></script>
		<% } %>
  </head>
  <body>
		<%= content %>
		<div id="red_dot" class="circular_thumb dot">
			<span class="dot_info"><span>
		</div>
		<div id="yellow_dot" class="circular_thumb dot">
			<span class="dot_info"><span>
		</div>
		<div id="green_dot" class="circular_thumb dot">
			<span class="dot_info"><span>
		</div>
	</body>

</html>